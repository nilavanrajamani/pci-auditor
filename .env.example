# PCI Auditor — Environment Configuration
# =========================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is git-ignored and never committed.
# All keys are optional unless marked REQUIRED.


# ---------------------------------------------------------------------------
# Azure OpenAI  (REQUIRED for AI scan mode)
# ---------------------------------------------------------------------------

# Full endpoint URL for your Azure OpenAI resource.
# Format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key for the Azure OpenAI resource.
AZURE_OPENAI_API_KEY=

# Name of the chat-completion deployment (e.g. a GPT-4o deployment).
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version to use. Check Azure docs for latest stable version.
AZURE_OPENAI_API_VERSION=2024-02-01


# ---------------------------------------------------------------------------
# Semantic Rule Retrieval / RAG  (optional — improves accuracy and cuts cost)
# ---------------------------------------------------------------------------

# Name of the text-embedding deployment.
# Required to use 'pci-auditor rules index-build'.
# Recommended model: text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Optional: use a DIFFERENT Azure OpenAI resource for embeddings.
# Leave blank to share AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_API_KEY above.
# AZURE_OPENAI_EMBEDDING_ENDPOINT=https://<other-resource>.openai.azure.com/
# AZURE_OPENAI_EMBEDDING_API_KEY=

# Number of top-matched rules to inject per code chunk (default: 8).
# Lower = cheaper prompts; higher = broader coverage.
PCI_AUDITOR_TOP_K_RULES=8


# ---------------------------------------------------------------------------
# Azure AI Search  (optional — alternative to local cosine-similarity index)
# ---------------------------------------------------------------------------

# Full endpoint URL for your Azure AI Search service.
# Format: https://<search-resource>.search.windows.net
AZURE_SEARCH_ENDPOINT=

# Admin or query API key for the Azure AI Search service.
AZURE_SEARCH_API_KEY=

# Name of the search index to create/use (default: pci-rules).
AZURE_SEARCH_INDEX_NAME=pci-rules


# ---------------------------------------------------------------------------
# Scan behaviour  (optional overrides)
# ---------------------------------------------------------------------------

# Comma-separated severities that fail the build (default: critical,high).
# PCI_AUDITOR_FAIL_ON=critical,high

# Set to 1 to disable AI analysis and use pattern matching only.
# PCI_AUDITOR_NO_AI=0

# URL to fetch updated rules JSON from (no default — must be supplied explicitly).
# PCI_AUDITOR_RULES_SOURCE=
